# ============================================================
# PORTAL TUCAN — Variáveis de Ambiente
#
# INSTRUÇÕES:
#   1. Copie este arquivo:  cp .env.example .env.local
#   2. Preencha os valores  (veja README.md para onde encontrar cada um)
#   3. NUNCA commite o .env.local — ele está no .gitignore
# ============================================================

# ── Supabase (obrigatório) ────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App (obrigatório) ─────────────────────────────────────────
# Em desenvolvimento: http://localhost:3000
# Em produção: https://portal.agenciatucan.com.br

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Portal Tucan

# ── Resend — E-mails automáticos (opcional) ───────────────────
# Crie uma conta gratuita em resend.com
# Sem estas variáveis, e-mails simplesmente não são enviados

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@agenciatucan.com.br
RESEND_FROM_NAME=Tucan Marketing Digital

# ── Segurança (opcional, mas recomendado em produção) ─────────
# Gere um valor aleatório com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

APPROVAL_TOKEN_SECRET=coloque_um_secret_aleatorio_de_64_chars_aqui
CRON_SECRET=outro_secret_aleatorio_para_jobs_agendados

# ── Google Agenda — sincronização de eventos internos (opcional) ─
# Crie um projeto em console.cloud.google.com, ative a Google Calendar API
# e gere uma credencial OAuth 2.0 (Web application) com redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/google/oauth/callback
#
# GOOGLE_TOKEN_ENCRYPTION_KEY: gere com
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_TOKEN_ENCRYPTION_KEY=coloque_um_secret_aleatorio_de_64_chars_aqui

# ── Limites de upload ─────────────────────────────────────────
# Valor em bytes — 52428800 = 50MB

MAX_FILE_SIZE_BYTES=52428800
